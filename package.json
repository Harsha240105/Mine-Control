{
  "name": "minecontrol-os",
  "version": "1.0.22",
  "description": "Self-hosted Minecraft Server Management Platform",
  "author": "Harsha <hsharshavardhanh@soundaryainstitutions.in>",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev:electron": "electron .",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:desktop": "npm run build && npm run build:electron && npx electron-rebuild -f -w better-sqlite3 && electron-builder && npm rebuild better-sqlite3",
    "build:desktop:win": "npm run build && npm run build:electron && npx electron-rebuild -f -w better-sqlite3 && electron-builder --win && npm rebuild better-sqlite3",
    "build:desktop:mac": "npm run build && npm run build:electron && npx electron-rebuild -f -w better-sqlite3 && electron-builder --mac && npm rebuild better-sqlite3",
    "build:desktop:linux": "npm run build && npm run build:electron && npx electron-rebuild -f -w better-sqlite3 && electron-builder --linux && npm rebuild better-sqlite3",
    "start": "node dist/server/index.js",
    "start:electron": "electron dist/electron/main.js",
    "postinstall": "npm rebuild better-sqlite3 2>nul || exit 0",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/three": "^0.184.1",
    "archiver": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.5.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "gif-encoder-2": "^1.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pidusage": "^3.0.2",
    "socket.io": "^4.7.2",
    "systeminformation": "^5.21.0",
    "three": "^0.184.0",
    "unzipper": "^0.10.14",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.41",
    "@types/react-dom": "^18.2.17",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.0.0",
    "concurrently": "^8.2.2",
    "date-fns": "^2.30.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.55.0",
    "lucide-react": "^0.294.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.10.3",
    "socket.io-client": "^4.7.2",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.6"
  }
}
