# Minecraft Server Paths
MC_DIR=/opt/minecraft/server
MC_LOG_DIR=/opt/minecraft/logs

# Dashboard Server
PORT=3001
NODE_ENV=production
JWT_SECRET=generate-a-random-secret-here
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=/opt/minecraft/dashboard/data/dashboard.db

# Webhook for alerts (optional)
WEBHOOK_URL=
